{
  "name": "jellyfish-backend-nestjs",
  "version": "0.1.0",
  "description": "AI 驱动的短剧制作平台后端 (NestJS 版本)",
  "author": "",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@9.x",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest coverage",
    "test:debug": "vitest --inspect-brk --environment node",
    "test:unit": "vitest run --testNamePattern=\"^((?!integration|e2e).)*$\"",
    "test:integration": "vitest run -c vitest.config.ts --testNamePattern=\"integration\"",
    "test:e2e": "vitest run -c vitest.config.ts --testNamePattern=\"e2e\"",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.0",
    "@nestjs/core": "^10.4.0",
    "@nestjs/platform-express": "^10.4.0",
    "@nestjs/swagger": "^8.0.0",
    "@nestjs/config": "^3.3.0",
    "@prisma/client": "^7.0.0",
    "@langchain/core": "^1.x",
    "@langchain/openai": "^1.x",
    "@langchain/langgraph": "^1.x",
    "zod": "^3.23.0",
    "nestjs-zod": "^4.0.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.0",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^10.4.0",
    "@types/express": "^4.17.21",
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^2.1.0",
    "dotenv": "^17.3.1",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "prettier": "^3.3.0",
    "prisma": "^7.0.0",
    "source-map-support": "^0.5.21",
    "ts-loader": "^9.5.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0",
    "typescript-eslint": "^8.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/engines",
      "prisma"
    ]
  }
}
