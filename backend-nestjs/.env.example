# Jellyfish Backend NestJS - 环境变量示例
# 复制为 .env 后按需修改

# 应用
APP_NAME=Jellyfish API
DEBUG=false
LOG_LEVEL=debug

# API
API_V1_PREFIX=/api/v1
PORT=3000

# 数据库（默认 SQLite）
DATABASE_URL="file:./dev.db"
# PostgreSQL 示例:
# DATABASE_URL="postgresql://user:pass@localhost:5432/jellyfish?schema=public"
# MySQL 示例:
# DATABASE_URL="mysql://user:pass@localhost:3306/jellyfish"

# CORS 前端地址（逗号分隔）
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# OpenAI API（必需）
OPENAI_API_KEY=sk-...

# Anthropic API（可选）
# ANTHROPIC_API_KEY=sk-ant-...

# 图片生成（用于演员/角色/道具/场景/服装/镜头帧图片生成任务）
# IMAGE_API_PROVIDER=openai
# IMAGE_API_BASE_URL=https://example.com/v1/images/generations
# IMAGE_API_KEY=your-image-api-key

# 视频生成（用于 /film/generated_video 等接口）
# VIDEO_API_PROVIDER=openai
# VIDEO_API_BASE_URL=https://example.com/v1/videos/generations
# VIDEO_API_KEY=your-video-api-key

# S3 / 对象存储（素材文件）
# 如使用 AWS S3 或兼容 S3 的服务，可按需填写：
# S3_ENDPOINT_URL=https://s3.amazonaws.com
# S3_REGION_NAME=ap-southeast-1
# S3_ACCESS_KEY_ID=your-access-key-id
# S3_SECRET_ACCESS_KEY=your-secret-key
# S3_BUCKET_NAME=jellyfish-assets
# 可选统一前缀，方便按环境/项目隔离，如 jellyfish/dev
# S3_BASE_PATH=jellyfish/dev
# 若有 CDN/自定义域名，可配置成 https://cdn.example.com
# S3_PUBLIC_BASE_URL=
